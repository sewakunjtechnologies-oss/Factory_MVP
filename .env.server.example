# Copy this file to .env on the server laptop:
#   cp .env.server.example .env
#
# Keep .env private. It is ignored by Git.

APP_PORT=8000

ENVIRONMENT=production
DATABASE_URL=sqlite+aiosqlite:///./data/factory.db
REPORT_OUTPUT_DIR=./backend/generated_reports
UPLOAD_DIR=./backend/uploads

# Required for AI assistant / Gemini-backed answers.
GEMINI_API_KEY=replace-with-your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-preview-native-audio-dialog

# Replace with a long random value before real use:
#   openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-secret

# 7 days
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Disable public signup on owner testing deployments after creating accounts.
ALLOW_PUBLIC_REGISTRATION=false

# For local/LAN testing. Tighten this when you put it behind a fixed domain.
CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173","capacitor://localhost"]
CORS_ORIGIN_REGEX=
DISABLE_SCHEDULER=false
