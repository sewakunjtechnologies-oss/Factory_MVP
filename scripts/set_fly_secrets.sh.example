#!/usr/bin/env bash
set -euo pipefail

APP_NAME="${1:-factory-control-owner-test}"

flyctl secrets set -a "$APP_NAME" \
  SECRET_KEY="replace-with-production-secret" \
  GEMINI_API_KEY="replace-with-rotated-gemini-key" \
  DATABASE_URL="sqlite+aiosqlite:////app/data/factory.db" \
  REPORT_OUTPUT_DIR="/app/data/generated_reports" \
  UPLOAD_DIR="/app/data/uploads" \
  CORS_ORIGINS='["capacitor://localhost","https://factory-control-owner-test.fly.dev"]' \
  ENVIRONMENT="production" \
  ALLOW_PUBLIC_REGISTRATION="false" \
  DISABLE_SCHEDULER="false"
