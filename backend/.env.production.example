APP_NAME=Factory Owner MVP
API_V1_PREFIX=/api/v1
ENVIRONMENT=production
DATABASE_URL=sqlite+aiosqlite:////app/data/factory.db
REPORT_OUTPUT_DIR=/app/data/generated_reports
UPLOAD_DIR=/app/data/uploads
SECRET_KEY=replace-with-openssl-rand-hex-48
ACCESS_TOKEN_EXPIRE_MINUTES=10080
ALGORITHM=HS256
GEMINI_API_KEY=replace-with-rotated-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_LIVE_MODEL=gemini-2.5-flash-preview-native-audio-dialog
CORS_ORIGINS=["capacitor://localhost","https://factory-control-owner-test.fly.dev"]
CORS_ORIGIN_REGEX=
ALLOW_PUBLIC_REGISTRATION=false
DISABLE_SCHEDULER=false
